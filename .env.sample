# ========================================
# Security Configuration
# ========================================

# reCAPTCHA v3 (Bot Protection)
VITE_RECAPTCHA_SITE_KEY=6LctXX0sAAAAAD07AC3tH5PyRnQnZaRbz0FPfFN8
RECAPTCHA_SECRET_KEY=6LctXX0sAAAAACDxBIKQd4J5ec3h0c0dskjdkc

# reCAPTCHA Score Thresholds (0.0-1.0, lower = stricter)
# 0.0 = definite bot, 1.0 = definite human
RECAPTCHA_REGISTER_MIN_SCORE=0.5    # Registration requires medium-high confidence
RECAPTCHA_LOGIN_MIN_SCORE=0.3       # Login is more lenient
RECAPTCHA_SUBMIT_MIN_SCORE=0.5      # Shop submission requires medium-high confidence
RECAPTCHA_VOTE_MIN_SCORE=0.4        # Voting requires moderate confidence
RECAPTCHA_RESET_MIN_SCORE=0.3       # Password reset is lenient

# Rate Limiting (per IP address)
RATE_LIMIT_REGISTER_PER_HOUR=5      # Max new accounts per IP per hour
RATE_LIMIT_LOGIN_PER_HOUR=10        # Max login attempts per IP per hour
RATE_LIMIT_VOTE_PER_HOUR=50         # Max votes per IP per hour
RATE_LIMIT_PASSWORD_RESET_PER_HOUR=3  # Max password resets per IP per hour
RATE_LIMIT_SHOP_SUBMIT_PER_HOUR=10  # Max shop submissions per IP per hour (in addition to per-user limits)

# IP Auto-Blocking
IP_AUTO_BLOCK_ENABLED=true          # Enable automatic IP blocking
IP_AUTO_BLOCK_THRESHOLD=50          # Block IP after this many rate limit violations
IP_AUTO_BLOCK_LOW_SCORE_COUNT=5     # Block IP after this many low reCAPTCHA scores (<0.2)
IP_AUTO_BLOCK_DURATION_HOURS=24     # How long to block IPs (hours)

# Email Verification Enforcement
REQUIRE_EMAIL_VERIFICATION=true     # Require verified email for protected actions

# Stripe Payment Validation
STRIPE_MEMBERSHIP_PRICE_CENTS=500   # Expected payment amount in cents ($5.00)
VALIDATE_PAYMENT_AMOUNT=true        # Verify payment amounts match expected price